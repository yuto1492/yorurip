# =============================================================================
# 公開しても OK な値 (browser bundle に含まれる前提)
# =============================================================================

# Supabase Project URL (例: https://xxxxxxxxxxxx.supabase.co)
SUPABASE_URL=

# Supabase Anon / Publishable Key (RLS 前提で公開しても安全な設計)
# legacy 形式 (eyJ...) でも 新形式 (sb_publishable_xxx) でも可
SUPABASE_KEY=

# =============================================================================
# サーバ側のみ。絶対に漏らさない (browser に届かない)
# =============================================================================

# Anthropic Claude API Key (生成 / 口調分析で使う)
# Console: https://console.anthropic.com/settings/keys
NUXT_ANTHROPIC_API_KEY=

# Supabase Service Role Key (RLS バイパス権限。auth admin API も使用)
# 用途: 匿名→email 移行 / アカウント完全削除 / JWE access_token の検証
# 漏れると全データ流出 + 全ユーザー操作可能になるので絶対に公開しない
# Project Settings → API → service_role secret
SUPABASE_SERVICE_KEY=

# =============================================================================
# 任意 (P1 以降)
# =============================================================================

# Sentry / Plausible 等の監視用
# SENTRY_DSN=
# PLAUSIBLE_DOMAIN=
